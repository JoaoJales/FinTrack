# ------------------------------------------------------------------------------
# Checklist rápido — produção (revise antes do deploy; o restante deste arquivo
# reflete desenvolvimento local. Não copie sem rever cada ponto.)
# ------------------------------------------------------------------------------
# [ ] APP_ENV=production
# [ ] APP_DEBUG=false — em produção, true expõe stack traces e detalhes internos
# [ ] APP_KEY definida (php artisan key:generate) e nunca versionada
# [ ] APP_URL com https:// e igual ao domínio público real da aplicação
# [ ] Com tráfego só por HTTPS: SESSION_SECURE_COOKIE=true (cookie não circula em HTTP)
# [ ] Opcional: SESSION_ENCRYPT=true para cifrar o payload da sessão no Redis/BD/arquivos
# [ ] SESSION_SAME_SITE=lax, strict ou none — avaliar cross-site / iframes; "none" exige Secure
# ------------------------------------------------------------------------------

APP_NAME=FinTrack
APP_ENV=local
APP_KEY=
# Em produção: false (ver checklist no topo)
APP_DEBUG=true
# Em produção: use https:// e o domínio real (ver checklist no topo)
APP_URL=http://localhost:8080

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fintrack
DB_USERNAME=fintrack
DB_PASSWORD=secret

# Testes (`php artisan test` / phpunit.xml): PostgreSQL, banco `fintrack_testing`,
# mesmas credenciais por padrão. Crie o banco antes de rodar a suíte (ver README).

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
# Em produção: considere true se quiser dados de sessão cifrados no armazenamento (ver checklist)
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Produção com HTTPS: defina true (ou descomente). Em HTTP local omita a variável.
# SESSION_SECURE_COOKIE=true
# lax (padrão Laravel), strict ou none — ajuste a integrações cross-site (ver checklist)
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@fintrack.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
